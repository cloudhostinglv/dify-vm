# Caddyfile — TLS front for a Dify builder VM (CONVENTION across all products):
#
#   :443  -> Dify's own nginx (127.0.0.1:8080)   <- the product, "Open Dify"
#   :8443 -> the CloudHosting AI Panel (127.0.0.1:8081)  <- panel is ALWAYS on 8443
#   :80   -> ACME HTTP-01
#
# Caddy runs in HOST network mode (see panel-compose.yml) so it reaches BOTH Dify's
# nginx and our panel over the host loopback. Dify ships its own nginx (TLS off;
# EXPOSE_NGINX_PORT=8080); we moved Dify's unused SSL port off 8443 so it never
# collides with our panel. PANEL_DOMAIN is injected from the environment.

{
	email admin@cloudhosting.lv
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory   # uncomment while testing
}

# --- :443 — the Dify product (its own nginx) ------------------------------- #
{$PANEL_DOMAIN}:443 {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8080 {
		# Dify uses Socket.IO/WebSocket; preserve Host/scheme for correct URLs.
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
	}
	request_body {
		max_size 100MB
	}
}

# --- :8443 — the branded CloudHosting AI Panel ----------------------------- #
{$PANEL_DOMAIN}:8443 {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8081 {
		transport http {
			dial_timeout 10s
			response_header_timeout 30s
		}
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
	request_body {
		max_size 256KB
	}
}
