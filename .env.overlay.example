# .env.overlay.example — per-VM values layered ON TOP of Dify's own docker/.env
# ---------------------------------------------------------------------------
# provision.sh starts from Dify's upstream docker/.env.example and then sets
# each key below. This file is the committed template; the real overlay is
# generated per client at provision time (see autoinstall-snippet.yaml) and is
# gitignored (**/.env). Never commit a filled-in copy.
#
# Only the values that DIFFER per VM (or that we deliberately override) live
# here. Everything else stays at Dify's upstream defaults.
# ---------------------------------------------------------------------------

# --- Per-VM identity / secret -------------------------------------------------
# UNIQUE per VM. Generate with:  openssl rand -base64 42
# Credentials (incl. the avots key) are stored ENCRYPTED in Postgres keyed by
# this value. Reusing a key across VMs, or changing it after first boot, breaks
# decryption of every stored provider credential. provision.sh generates one if
# left blank, but cloud-init normally injects it so it is captured in the image
# build record.
SECRET_KEY=

# --- Public hostname ----------------------------------------------------------
# The client subdomain Caddy terminates TLS for, e.g. ai.client.example.
DOMAIN=

# --- avots backend (this client's OWN key) -----------------------------------
# Used by provision.sh's best-effort console-API step to register the avots
# provider. Format: av_mcp_<key>. If the API step fails, this key is printed in
# the manual wiring instructions instead.
AVOTS_API_KEY=av_mcp_REPLACE_ME
AVOTS_BASE_URL=https://api.avots.ai/openai/v1
AVOTS_MODEL=anthropic/claude-opus-4.8
# Context window advertised to Dify for the avots model (tokens). 200000 is a
# safe value for Claude Opus; adjust if you front a smaller model.
AVOTS_MODEL_CONTEXT=200000

# --- nginx / exposure ---------------------------------------------------------
# Caddy fronts Dify and owns 80/443, so Dify's own nginx does plain HTTP on an
# internal host port only. We publish container:80 on host:8080 (loopback via
# Caddy) and DO NOT publish 443.
NGINX_HTTPS_ENABLED=false
EXPOSE_NGINX_PORT=8080
EXPOSE_NGINX_SSL_PORT=8443
# Reflected into CONSOLE_*/APP_*/FILES_* URLs by provision.sh from DOMAIN.
# (Left here for visibility; provision.sh derives the actual values.)

# --- plugin install (offline / baked image) ----------------------------------
# Allow installing the OpenAI-API-compatible provider plugin from a local
# .difypkg without a marketplace signature. Also raise upload size limits so a
# repackaged (deps-bundled) plugin fits.
FORCE_VERIFYING_SIGNATURE=false
PLUGIN_MAX_PACKAGE_SIZE=524288000
NGINX_CLIENT_MAX_BODY_SIZE=100M
